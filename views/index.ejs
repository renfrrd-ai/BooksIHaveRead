<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Books I Have Read</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 [font-family:'Manrope',sans-serif]">
    <div class="relative isolate overflow-hidden">
      <div class="pointer-events-none absolute -top-24 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-fuchsia-600/30 blur-3xl"></div>
      <div class="pointer-events-none absolute bottom-0 left-0 h-72 w-72 rounded-full bg-cyan-500/20 blur-3xl"></div>

      <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <header class="mb-10 rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-sm sm:p-8">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-cyan-300">Reading Archive</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">Books I Have Read</h1>
        <p class="mt-3 max-w-2xl text-slate-300">
          A personal list of books, notes, ratings, and takeaways worth revisiting.
        </p>
      </header>

      <% const books = Array.isArray(locals.books) ? locals.books : []; %>

      <% if (books.length === 0) { %>
      <section class="rounded-3xl border border-dashed border-white/20 bg-white/5 p-10 text-center backdrop-blur-sm">
        <h2 class="text-xl font-semibold text-white">No books yet</h2>
        <p class="mt-2 text-slate-300">
          Add your first book to start tracking your reading history.
        </p>
      </section>
      <% } else { %>
      <section class="grid gap-6 lg:grid-cols-2">
        <% books.forEach((book) => { %>
        <article class="group rounded-3xl border border-white/10 bg-gradient-to-br from-slate-900/90 to-slate-800/80 p-5 shadow-2xl transition hover:-translate-y-1 hover:border-cyan-300/40 hover:shadow-cyan-900/30 sm:p-6">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
            <div class="shrink-0">
              <% if (book.link) { %>
              <img
                src="<%= book.link %>"
                alt="Cover of <%= book.title %> by <%= book.author %>"
                class="h-44 w-32 rounded-xl border border-white/15 object-cover shadow-lg shadow-black/40 sm:h-48 sm:w-36"
                loading="lazy"
              />
              <% } else { %>
              <div class="flex h-44 w-32 items-center justify-center rounded-xl border border-dashed border-white/20 bg-slate-900/60 text-xs font-semibold uppercase tracking-wider text-slate-400 sm:h-48 sm:w-36">
                No cover
              </div>
              <% } %>
            </div>

            <div class="flex-1">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-xl font-bold text-white"><%= book.title %></h2>
                  <p class="mt-1 text-sm text-slate-300">by <%= book.author %></p>
                </div>
                <div class="rounded-full bg-gradient-to-r from-amber-300 to-orange-400 px-3 py-1 text-sm font-extrabold text-slate-900 shadow-md">
                  <%= book.rating %>/10
                </div>
              </div>

              <p class="mt-4 text-sm leading-6 text-slate-200/95">
                <%= book.description %>
              </p>

              <p class="mt-4 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-300/90">
                Read on:
                <span class="text-slate-200"><%= book.date_read.toLocaleDateString() %></span>
              </p>
            </div>
          </div>
        </article>
        <% }); %>
      </section>
      <% } %>
      </main>
    </div>
  </body>
</html>
