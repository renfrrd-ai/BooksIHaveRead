<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Books I Have Read</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
      <header class="mb-10">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Books I Have Read</h1>
        <p class="mt-3 text-slate-600">
          A personal list of books, notes, and ratings.
        </p>
      </header>

      <% const books = Array.isArray(locals.books) ? locals.books : []; %>

      <% if (books.length === 0) { %>
      <section class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center">
        <h2 class="text-xl font-semibold">No books yet</h2>
        <p class="mt-2 text-slate-600">
          Add your first book to start tracking your reading history.
        </p>
      </section>
      <% } else { %>
      <section class="grid gap-6 sm:grid-cols-2">
        <% books.forEach((book) => { %>
        <article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-semibold"><%= book.title %></h2>
              <p class="mt-1 text-sm text-slate-600">by <%= book.author %></p>
            </div>
            <div class="rounded-full bg-amber-100 px-3 py-1 text-sm font-semibold text-amber-800">
              <%= book.rating %>/10
            </div>
          </div>

          <p class="mt-4 text-sm leading-6 text-slate-700">
            <%= book.description %>
          </p>

          <p class="mt-4 text-xs uppercase tracking-wide text-slate-500">
            Read on:
            <span class="font-medium text-slate-700"><%= book.date_read.toLocaleDateString() %></span>
          </p>
        </article>
        <% }); %>
      </section>
      <% } %>
    </main>
  </body>
</html>
